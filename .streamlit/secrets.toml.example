# ============================================================================
#  EXEMPLO de secrets do Streamlit  —  Dashboard de Captação (PFC)
# ----------------------------------------------------------------------------
#  COMO USAR
#  1. Copie este arquivo para  .streamlit/secrets.toml  (sem o ".example").
#  2. Preencha o bloco [gcp_service_account] com os dados da sua conta de
#     serviço Google (veja o passo a passo no README.md).
#  3. Informe a planilha em UMA das três formas: spreadsheet_url,
#     spreadsheet_key ou spreadsheet_name.
#  4. Compartilhe a planilha do Google com o e-mail "client_email" abaixo,
#     dando permissão de EDITOR.
#
#  IMPORTANTE: o arquivo .streamlit/secrets.toml NUNCA deve ir para o Git
#  (já está no .gitignore). Sem este arquivo, o app roda em modo CSV.
# ============================================================================

# ---- Como localizar a planilha (escolha apenas uma) ----
# spreadsheet_url = "https://docs.google.com/spreadsheets/d/SEU_ID_AQUI/edit"
# spreadsheet_key = "1AbCdEfGhIjKlMnOpQrStUvWxYz0123456789"
# spreadsheet_name = "PFC Captação"

# ---- Conta de serviço Google (descomente e preencha) ----
# [gcp_service_account]
# type = "service_account"
# project_id = "seu-projeto-123456"
# private_key_id = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# private_key = "-----BEGIN PRIVATE KEY-----\nLINHA1\nLINHA2\n...\n-----END PRIVATE KEY-----\n"
# client_email = "minha-conta@seu-projeto-123456.iam.gserviceaccount.com"
# client_id = "1234567890123456789"
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/minha-conta%40seu-projeto.iam.gserviceaccount.com"
# universe_domain = "googleapis.com"
